{
  "root": true,
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": ["airbnb-base", "prettier"],
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["error", { "args": "after-used", "argsIgnorePattern": "^_" }]
  }
}
